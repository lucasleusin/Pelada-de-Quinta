generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Position {
  GOLEIRO
  ZAGUEIRO
  MEIA
  ATACANTE
  OUTRO
}

enum MatchStatus {
  DRAFT
  CONFIRMATION_OPEN
  TEAMS_LOCKED
  FINISHED
  ARCHIVED
}

enum PresenceStatus {
  CONFIRMED
  WAITLIST
  CANCELED
}

enum Team {
  A
  B
}

enum WhatsAppProvider {
  TWILIO
}

enum WhatsAppMessageDirection {
  OUTBOUND
  INBOUND
}

enum WhatsAppMessageEventType {
  CONFIRM
  CANCEL
  TEST
}

enum WhatsAppMessageStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

model Player {
  id                    String             @id @default(uuid())
  name                  String             @unique
  position              Position           @default(OUTRO)
  shirtNumberPreference Int?
  email                 String?            @unique
  phone                 String?
  photoUrl              String?
  photoPath             String?
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  participants          MatchParticipant[]
  ratingsGiven          MatchRating[]      @relation("RatingsGiven")
  ratingsReceived       MatchRating[]      @relation("RatingsReceived")
  statsUpdatedEntries   MatchParticipant[] @relation("StatsUpdatedBy")
  whatsAppMessages      WhatsAppMessageLog[]

  @@index([name])
  @@map("players")
}

model Match {
  id               String               @id @default(uuid())
  matchDate        DateTime             @db.Date
  location         String?
  startTime        String               @default("19:00")
  status           MatchStatus          @default(DRAFT)
  teamAName        String               @default("Time A")
  teamBName        String               @default("Time B")
  teamAScore       Int?
  teamBScore       Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  participants     MatchParticipant[]
  ratings          MatchRating[]
  whatsAppMessages WhatsAppMessageLog[]

  @@index([matchDate, status])
  @@map("matches")
}

model MatchParticipant {
  id                     String         @id @default(uuid())
  matchId                String
  playerId               String
  presenceStatus         PresenceStatus @default(CANCELED)
  confirmedAt            DateTime?
  teams                  Team[]         @default([])
  playedAsGoalkeeper     Boolean        @default(false)
  teamAGoals             Int            @default(0)
  teamAAssists           Int            @default(0)
  teamAGoalsConceded     Int            @default(0)
  teamBGoals             Int            @default(0)
  teamBAssists           Int            @default(0)
  teamBGoalsConceded     Int            @default(0)
  goals                  Int            @default(0)
  assists                Int            @default(0)
  goalsConceded          Int            @default(0)
  statsUpdatedByPlayerId String?
  statsUpdatedAt         DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  match                Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player               Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  statsUpdatedByPlayer Player? @relation("StatsUpdatedBy", fields: [statsUpdatedByPlayerId], references: [id], onDelete: SetNull)

  @@unique([matchId, playerId])
  @@index([matchId, presenceStatus])
  @@index([matchId, confirmedAt])
  @@index([playerId])
  @@map("match_participants")
}

model MatchRating {
  id            String   @id @default(uuid())
  matchId       String
  raterPlayerId String
  ratedPlayerId String
  rating        Int
  createdAt     DateTime @default(now())

  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterPlayer Player @relation("RatingsGiven", fields: [raterPlayerId], references: [id], onDelete: Cascade)
  ratedPlayer Player @relation("RatingsReceived", fields: [ratedPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchId, raterPlayerId, ratedPlayerId])
  @@index([matchId, ratedPlayerId])
  @@map("match_ratings")
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

model WhatsAppSettings {
  id              String             @id @default("default")
  enabled         Boolean            @default(false)
  provider        WhatsAppProvider   @default(TWILIO)
  notifyOnConfirm Boolean            @default(true)
  notifyOnCancel  Boolean            @default(true)
  confirmTemplate String
  cancelTemplate  String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  recipients      WhatsAppRecipient[]

  @@map("whatsapp_settings")
}

model WhatsAppRecipient {
  id         String              @id @default(uuid())
  settingsId String
  label      String
  phoneE164  String
  isActive   Boolean             @default(true)
  lastTestAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  settings   WhatsAppSettings    @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  messages   WhatsAppMessageLog[]

  @@unique([settingsId, phoneE164])
  @@index([settingsId, isActive])
  @@map("whatsapp_recipients")
}

model WhatsAppMessageLog {
  id                String                   @id @default(uuid())
  direction         WhatsAppMessageDirection @default(OUTBOUND)
  eventType         WhatsAppMessageEventType
  provider          WhatsAppProvider         @default(TWILIO)
  providerMessageId String?
  recipientPhone    String?
  body              String
  status            WhatsAppMessageStatus    @default(QUEUED)
  errorMessage      String?
  rawPayload        Json?
  playerId          String?
  matchId           String?
  recipientId       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  player    Player?            @relation(fields: [playerId], references: [id], onDelete: SetNull)
  match     Match?             @relation(fields: [matchId], references: [id], onDelete: SetNull)
  recipient WhatsAppRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([playerId, matchId])
  @@map("whatsapp_message_logs")
}

